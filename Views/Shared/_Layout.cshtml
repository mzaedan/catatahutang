<!DOCTYPE html>
<html lang="id">
<head>
    @await Html.PartialAsync("_Styles.cshtml")
</head>
<body>
    <div class="app-shell container-fluid px-0">
        <partial name="_Sidebar" />

        <div class="workspace">
            <partial name="_Header" />

            <main role="main" class="page-content container-fluid">
                @RenderBody()
            </main>

            <partial name="_Footer" />
        </div>
    </div>

    <partial name="_Scripts" />
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
