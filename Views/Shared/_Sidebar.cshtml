@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
}

<aside class="sidebar">
    <a class="brand text-decoration-none" asp-area="" asp-controller="Dashboard" asp-action="Index">
        <span class="brand-mark">C</span>
        <span>
            <strong>CatatBon</strong>
            <small>Toko Kelontong Berkah</small>
        </span>
    </a>

    <nav class="side-nav" aria-label="Navigasi utama">
        <a class="side-link @(currentController == "Dashboard" ? "active" : "") text-decoration-none" asp-area="" asp-controller="Dashboard" asp-action="Index">
            <span class="nav-icon" aria-hidden="true">[D]</span>
            <span>Dashboard</span>
        </a>
        <a class="side-link side-link-pelanggan @(currentController == "Pelanggan" ? "active" : "") text-decoration-none" asp-area="" asp-controller="Pelanggan" asp-action="Index">
            <span class="nav-icon" aria-hidden="true">[P]</span>
            <span>Pelanggan</span>
        </a>
        <a class="side-link @(currentController == "Barang" ? "active" : "") text-decoration-none" asp-area="" asp-controller="Barang" asp-action="Index">
            <span class="nav-icon" aria-hidden="true">[B]</span>
            <span>Barang</span>
        </a>
        <a class="side-link @(currentController == "CatatBon" ? "active" : "") text-decoration-none" asp-area="" asp-controller="CatatBon" asp-action="Index">
            <span class="nav-icon" aria-hidden="true">[C]</span>
            <span>Catat Bon</span>
        </a>
    </nav>
</aside>
