@model List<catatanHutang.Models.Pelanggan.User>
@{
    ViewData["Title"] = "Data Pelanggan";

    var successMessage = TempData["SuccessMessage"] as string;
    Func<string, (string Initial, string Tone)> resolveInitial = name =>
    {
        if (string.IsNullOrWhiteSpace(name))
            return ("?", "initial-gray");

        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        var initials = parts.Length == 1
            ? parts[0].Substring(0, Math.Min(2, parts[0].Length)).ToUpperInvariant()
            : string.Concat(parts[0][0], parts[parts.Length - 1][0]).ToUpperInvariant();

        var tone = (initials[0] % 3) switch
        {
            0 => "initial-red",
            1 => "initial-green",
            _ => "initial-blue"
        };

        return (initials, tone);
    };
}

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success customer-alert" role="status">
        <span class="alert-icon" aria-hidden="true">&#10003;</span>
        <span>@successMessage</span>
    </div>
}

<section class="customer-header">
    <div class="page-heading py-2">
        <h1 class="mb-0 fw-bold">Data Pelanggan</h1>
        <p class="mb-0 text-secondary">Kelola daftar pelanggan dan pantau status hutang mereka dengan mudah.</p>
    </div>

    <a asp-action="Create" class="add-customer-button text-decoration-none">
        <span aria-hidden="true">+</span>
        <span>Tambah Pelanggan</span>
    </a>
</section>

<section class="panel customer-list-panel">
    <div class="table-responsive">
        <table class="dashboard-table customer-table">
            <thead>
                <tr>
                    <th>Nama Pelanggan</th>
                    <th>No. HP</th>
                    <th>Alamat</th>
                    <th>Aksi</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Count > 0)
                {
                    @foreach (var item in Model)
                    {
                        var (initial, tone) = resolveInitial(item.NamaPelanggan);
                        <tr>
                            <td>
                                <span class="person @tone" aria-hidden="true">@initial</span>
                                <strong>@item.NamaPelanggan</strong>
                            </td>
                            <td>@item.NoHP</td>
                            <td><em>@item.Alamat</em></td>
                            <td>
                                <button class="customer-detail-button" type="button">Detail</button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="empty-state">
                            Belum ada pelanggan. Klik <strong>Tambah Pelanggan</strong> untuk menambahkan data pertama.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="table-footer">
        <p>Menampilkan @(Model?.Count ?? 0) pelanggan</p>
    </div>
</section>
