@{
    ViewData["Title"] = "Data Pelanggan";

    var pelanggan = new[]
    {
        new { Initial = "PB", Name = "Pak Budi", Phone = "08123456789", Address = "Jl. Merdeka No. 10", Debt = "Rp137.000", Tone = "initial-red" },
        new { Initial = "BA", Name = "Bu Ani", Phone = "08571234567", Address = "Gang Mawar", Debt = "Rp50.000", Tone = "initial-green" },
        new { Initial = "MA", Name = "Mas Agus", Phone = "08998877665", Address = "Depan Mushola", Debt = "Rp210.000", Tone = "initial-blue" },
        new { Initial = "SP", Name = "Siti Putri", Phone = "08129988221", Address = "Jl. Anggrek No. 5", Debt = "Rp0", Tone = "initial-green" }
    };
}

<section class="customer-header">
    <div class="page-heading py-2">
        <h1 class="mb-0 fw-bold">Data Pelanggan</h1>
        <p class="mb-0 text-secondary">Kelola daftar pelanggan dan pantau status hutang mereka dengan mudah.</p>
    </div>

    <button class="add-customer-button" type="button">
        <span aria-hidden="true">+</span>
        <span>Tambah Pelanggan</span>
    </button>
</section>

<section class="panel customer-list-panel">
    <div class="table-responsive">
        <table class="dashboard-table customer-table">
            <thead>
                <tr>
                    <th>Nama Pelanggan</th>
                    <th>No. HP</th>
                    <th>Alamat</th>
                    <th>Total Hutang</th>
                    <th>Aksi</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in pelanggan)
                {
                    <tr>
                        <td>
                            <span class="person @item.Tone" aria-hidden="true">@item.Initial</span>
                            <strong>@item.Name</strong>
                        </td>
                        <td>@item.Phone</td>
                        <td><em>@item.Address</em></td>
                        <td><strong>@item.Debt</strong></td>
                        <td>
                            <button class="customer-detail-button" type="button">Detail</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="table-footer">
        <p>Menampilkan 1 - 4 dari 48 Pelanggan</p>
        <nav class="pagination-bar" aria-label="Halaman data pelanggan">
            <button class="page-button muted" type="button" aria-label="Halaman sebelumnya">‹</button>
            <button class="page-button active" type="button" aria-current="page">1</button>
            <button class="page-button" type="button">2</button>
            <button class="page-button" type="button">3</button>
            <span class="page-dots">...</span>
            <button class="page-button" type="button">12</button>
            <button class="page-button" type="button" aria-label="Halaman berikutnya">›</button>
        </nav>
    </div>
</section>
