@model catatanHutang.Models.Barang.BarangViewModel
@{
    ViewData["Title"] = "Tambah Barang";
}

<section class="page-heading py-2 d-flex align-items-center gap-3">
    <a asp-action="Index" class="back-button" aria-label="Kembali ke daftar barang">
        <span aria-hidden="true">&#8592;</span>
    </a>
    <div>
        <h1 class="mb-0 fw-bold">Tambah Barang</h1>
        <p class="mb-0 text-secondary">Lengkapi informasi barang baru untuk ditambahkan ke daftar produk.</p>
    </div>
</section>

<section class="panel form-panel">
    <div class="panel-title">
        <h2>Informasi Barang</h2>
        <span class="text-secondary small">Field dengan tanda <span class="text-danger">*</span> wajib diisi.</span>
    </div>

    <form asp-action="Create" asp-controller="Barang" method="post" novalidate>
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

        <div class="form-grid">
            <div class="form-group">
                <label asp-for="NamaBarang" class="form-label">
                    <span>Nama Barang</span>
                    <span class="text-danger" aria-hidden="true">*</span>
                </label>
                <input asp-for="NamaBarang"
                       class="form-control"
                       placeholder="Contoh: Beras Premium 5kg"
                       autocomplete="off"
                       maxlength="150" />
                <span asp-validation-for="NamaBarang" class="text-danger small"></span>
            </div>

            <div class="form-group">
                <label asp-for="HargaJual" class="form-label">
                    <span>Harga Jual</span>
                    <span class="text-danger" aria-hidden="true">*</span>
                </label>
                <input asp-for="HargaJual"
                       class="form-control"
                       placeholder="Contoh: 75000"
                       inputmode="numeric"
                       autocomplete="off" />
                <span asp-validation-for="HargaJual" class="text-danger small"></span>
            </div>

            <div class="form-group">
                <label asp-for="Satuan" class="form-label">
                    <span>Satuan</span>
                    <span class="text-danger" aria-hidden="true">*</span>
                </label>
                <input asp-for="Satuan"
                       class="form-control"
                       placeholder="Contoh: Karung, Pcs, kg"
                       autocomplete="off"
                       maxlength="50" />
                <span asp-validation-for="Satuan" class="text-danger small"></span>
            </div>
        </div>

        <div class="form-actions">
            <a asp-action="Index" class="btn btn-secondary-action">Batal</a>
            <button type="submit" class="btn btn-primary-action">
                <span aria-hidden="true">+</span>
                <span>Simpan Barang</span>
            </button>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
