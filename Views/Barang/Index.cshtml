@model List<catatanHutang.Models.Barang.Barang>
@{
    ViewData["Title"] = "Master Data Barang";

    var successMessage = TempData["SuccessMessage"] as string;
    var errorMessage = TempData["ErrorMessage"] as string;
}

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success customer-alert" role="status">
        <span class="alert-icon" aria-hidden="true">&#10003;</span>
        <span>@successMessage</span>
    </div>
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger customer-alert customer-alert-danger" role="alert">
        <span class="alert-icon" aria-hidden="true">!</span>
        <span>@errorMessage</span>
    </div>
}

<section class="customer-header">
    <div class="page-heading py-2">
        <h1 class="mb-0 fw-bold">Master Data Barang</h1>
        <p class="mb-0 text-secondary">Kelola daftar produk, stok, dan harga jual tokomu.</p>
    </div>

    <a asp-action="Create" class="add-customer-button text-decoration-none">
        <span aria-hidden="true">+</span>
        <span>Tambah Barang</span>
    </a>
</section>

<section class="panel customer-list-panel">
    <div class="table-responsive">
        <table class="dashboard-table customer-table product-table">
            <thead>
                <tr>
                    <th>Nama Barang</th>
                    <th>Harga Jual</th>
                    <th>Satuan</th>
                    <th>Aksi</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Count > 0)
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <strong>@item.NamaBarang</strong>
                            </td>
                            <td><strong class="text-success">@item.HargaJual.ToString("N0")</strong></td>
                            <td>@item.Satuan</td>
                            <td>
                                <div class="inline-actions">
                                    <a asp-action="Edit"
                                       asp-route-id="@item.Id"
                                       class="icon-inline edit text-decoration-none"
                                       aria-label="Edit @item.NamaBarang">&#9998;</a>
                                    <form asp-action="Delete"
                                          asp-route-id="@item.Id"
                                          method="post"
                                          onsubmit="return confirm('Hapus barang ini?');">
                                        @Html.AntiForgeryToken()
                                        <button class="icon-inline delete"
                                                type="submit"
                                                aria-label="Hapus @item.NamaBarang">&#128465;</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="empty-state">
                            Belum ada barang. Klik <strong>Tambah Barang</strong> untuk menambahkan data pertama.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="table-footer">
        <p>Menampilkan @(Model?.Count ?? 0) barang</p>
    </div>
</section>
