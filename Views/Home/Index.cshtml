@{
    ViewData["Title"] = "Ringkasan Dashboard";
}

<section class="page-heading">
    <div>
        <h1>Ringkasan Dashboard</h1>
        <p>Pantau kesehatan keuangan tokomu secara real-time.</p>
    </div>
</section>

<section class="metric-grid" aria-label="Ringkasan keuangan">
    <article class="metric-card">
        <span class="metric-icon customers" aria-hidden="true">♙</span>
        <p>Total Pelanggan</p>
        <strong>124</strong>
    </article>
    <article class="metric-card">
        <span class="metric-icon money" aria-hidden="true">▣</span>
        <p>Hutang Aktif</p>
        <strong>Rp12.500.000</strong>
    </article>
    <article class="metric-card">
        <span class="metric-icon due" aria-hidden="true">▥</span>
        <p>Jatuh Tempo Hari Ini</p>
        <strong>8 Transaksi</strong>
    </article>
    <article class="metric-card">
        <span class="metric-icon danger" aria-hidden="true">!</span>
        <p>Telat Bayar</p>
        <strong>5 Transaksi</strong>
    </article>
    <article class="metric-card">
        <span class="metric-icon income" aria-hidden="true">▤</span>
        <p>Masuk Bulan Ini</p>
        <strong>Rp4.200.000</strong>
    </article>
</section>

<section class="dashboard-grid">
    <article class="panel debt-chart">
        <div class="panel-title">
            <h2>Tren Hutang vs Pelunasan</h2>
            <div class="legend">
                <span><i class="dot debt"></i>Hutang</span>
                <span><i class="dot paid"></i>Pelunasan</span>
            </div>
        </div>
        <div class="chart-stage" aria-label="Grafik tren hutang dan pelunasan">
            <div class="chart-line debt-line"></div>
            <div class="chart-line paid-line"></div>
            <div class="chart-labels">
                <span>Sen</span>
                <span>Sel</span>
                <span>Rab</span>
                <span>Kam</span>
                <span>Jum</span>
                <span>Sab</span>
                <span>Min</span>
            </div>
        </div>
    </article>

    <aside class="side-panels">
        <article class="saving-card">
            <span class="saving-badge" aria-hidden="true">▣</span>
            <p>Monitoring Tabung</p>
            <strong>42 Tabung</strong>
            <small>Belum Kembali ke Toko</small>
            <button type="button">Lihat Detail Pengembalian</button>
        </article>

        <article class="deposit-card">
            <p>Deposit Tabung Aktif</p>
            <strong>Rp1.470.000</strong>
            <span>6 Dana Aman Tersimpan</span>
        </article>
    </aside>
</section>

<section class="panel customer-panel">
    <div class="panel-title">
        <h2>Top 5 Pelanggan Hutang Terbesar</h2>
        <a href="#">Lihat Semua Pelanggan</a>
    </div>
    <div class="table-responsive">
        <table class="dashboard-table">
            <thead>
                <tr>
                    <th>Nama Pelanggan</th>
                    <th>Total Hutang</th>
                    <th>Status</th>
                    <th>Aksi</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><span class="person initial-green">BP</span>Budi Pratama</td>
                    <td>Rp2.450.000</td>
                    <td><span class="status late">Telat</span></td>
                    <td><button class="detail-button" type="button">Detail</button></td>
                </tr>
                <tr>
                    <td><span class="person initial-gray">SA</span>Siti Aminah</td>
                    <td>Rp1.820.000</td>
                    <td><span class="status safe">Aman</span></td>
                    <td><button class="detail-button" type="button">Detail</button></td>
                </tr>
                <tr>
                    <td><span class="person initial-gray">AD</span>Agus Darmawan</td>
                    <td>Rp1.150.000</td>
                    <td><span class="status safe">Aman</span></td>
                    <td><button class="detail-button" type="button">Detail</button></td>
                </tr>
                <tr>
                    <td><span class="person initial-green">HS</span>Hendro Susanto</td>
                    <td>Rp980.000</td>
                    <td><span class="status late">Telat</span></td>
                    <td><button class="detail-button" type="button">Detail</button></td>
                </tr>
                <tr>
                    <td><span class="person initial-gray">ML</span>Maya Larasati</td>
                    <td>Rp750.000</td>
                    <td><span class="status safe">Aman</span></td>
                    <td><button class="detail-button" type="button">Detail</button></td>
                </tr>
            </tbody>
        </table>
    </div>
</section>

<button class="floating-action" type="button" aria-label="Tambah catatan hutang">＋</button>
